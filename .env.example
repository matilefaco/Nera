# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=
NVIDIA_API_KEY=
RESEND_API_KEY=
# Remetente dos e-mails (Opcional, padrão: Nera <agenda@usenera.com>)
EMAIL_FROM=
VITE_API_URL=http://localhost:3000

# WHATSAPP META (Primary)
META_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# WHATSAPP Z-API (Secondary/Fallback)
ZAPI_INSTANCE_ID=
ZAPI_INSTANCE_TOKEN=
ZAPI_CLIENT_TOKEN=
ZAPI_BASE_URL=

# WHATSAPP LEGACY (Fallback)
# OPCIONAL: Se não configurado, o sistema usa apenas E-mail para lembretes
CALLMEBOT_API_KEY=
# OBRIGATÓRIO: Secret para validar a execução do CRON
CRON_SECRET=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# STRIPE
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ESSENCIAL=
STRIPE_PRICE_PRO=

# GOOGLE CALENDAR OAUTH
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# WEB PUSH NOTIFICATIONS
VITE_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
