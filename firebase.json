{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/debug-og/**",
        "function": {
          "functionId": "api",
          "region": "us-east1"
        }
      },
      {
        "source": "/p/**",
        "function": {
          "functionId": "api",
          "region": "us-east1"
        }
      },
      {
        "source": "/api/**",
        "function": {
          "functionId": "api",
          "region": "us-east1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": [
    {
      "source": ".",
      "codebase": "default",
      "predeploy": [
        "npm run build"
      ],
      "ignore": [
        "node_modules",
        ".git",
        "dist",
        "public",
        "src",
        ".firebase",
        "firebase-debug.log"
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
