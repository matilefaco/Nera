{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/debug-og/**",
        "run": {
          "serviceId": "ais-pre-63xlcjmrm7ywxwui656b4j-645724189341",
          "region": "us-east1"
        }
      },
      {
        "source": "/p/**",
        "run": {
          "serviceId": "ais-pre-63xlcjmrm7ywxwui656b4j-645724189341",
          "region": "us-east1"
        }
      },
      {
        "source": "/api/**",
        "run": {
          "serviceId": "ais-pre-63xlcjmrm7ywxwui656b4j-645724189341",
          "region": "us-east1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
