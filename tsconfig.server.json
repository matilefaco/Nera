{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist-server",
    "rootDir": ".",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "noEmit": false,
    "allowImportingTsExtensions": false
  },
  "include": ["server.ts", "server/**/*", "src/types.ts", "src/services/emailBuilder.ts"]
}
